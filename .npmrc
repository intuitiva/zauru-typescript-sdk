# Evita resolución doble de @types/* (p. ej. React) entre el store de pnpm y node_modules.
public-hoist-pattern[]=*@types*

# Publicación: fuerza el registry npmjs para el scope (si ~/.npmrc apunta a otro mirror, publish puede fallar con E404).
registry=https://registry.npmjs.org/
@zauru-sdk:registry=https://registry.npmjs.org/
