{
  "name": "zauru-sdk",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r exec rm -rf dist",
    "publish:packages": "lerna publish --registry https://registry.npmjs.org/ --no-verify-access",
    "publish:recursive": "pnpm -r publish --access public --no-git-checks --registry https://registry.npmjs.org/",
    "sync:workspace-protocol": "node scripts/sync-workspace-protocol.mjs"
  },
  "devDependencies": {
    "lerna": "^8.1.2"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
